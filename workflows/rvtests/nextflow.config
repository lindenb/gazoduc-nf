plugins {
  id 'nf-schema@2.6.1'
}

includeConfig "../../config/common.schema.config"


params {
	/** file prefix */
	prefix = ""
	/** output directory */
	outdir = "results"
	help = false
        /* TSV file with header: sample	status=case|control	sex=male|female|undefined , optional column 'population' */
	samplesheet = null
	
	/** vcf file , or if the suffix is '.list' , paths to the VCF  files */
	vcf = null

	/** limit analysis to the variants overlapping that BED file , used for STEP1 when building the correlation matrix , can be used to exclude sepecific low-mappability regions, etc...*/
	bed = null

   

        /** when this false functional annotation (missense, anonymous, etc, won't be used */
	with_functional_annotations  = true


        /** custom tab delimited file mapping functional annot . Mapping annotation to mask(s) : ANNOTATION(tab)SCORE[0-1](tab)MASK_NAME1(,MASK_NAME2,...)* . for functional annotation . See the main.nf for an example */
	custom_annotation2mask = null


        /* sliding window size: ([window_size,window_shift])+ */
	sliding_windows=""

        /** make circos plot  */
        with_circos = true
        /** start plotting circular plot if there is any LOG10 greater than this value*/
        circos_treshold = 5.0
        }

includeConfig "../../config/nextflow.config"


params {





	/** weight column for step 2 */
	weight_column = 4

	
	/** custom user bed chrom/start/end/annotation/gene_name[/score] .
	   BED records with different column annotation should not overlap .
	   Score is an optional column with a number between 0 and 1 
	   */
	select_bed = null
	

	/* treshold for digest file , hide pvalue lower than this value */
	digest_treshold  = 7.0


	/** when input is bed , and if bed record is just too small, extend each record to that length (like bedtools slop).  */
	min_bed_length = 0


	}

process {
        errorStrategy = "terminate"

        withName: "PREPARE_ONE_REFERENCE:PREPARE_REFERENCE:SCATTER_TO_BED:SCATTER_INTERVALS_BY_NS" {
                ext.output_type = "ACGT"
                ext.max_to_merge = 1
                }



        withName: "QQMAN"  {
                ext.cmd = "awk -F ' ' '/^CHROM/ {printf(\"CHR\\tBP\\tSNP\\tP\\n\");next;} {printf(\"%s\\t%s\\t%s\\t%s\\n\",\$1,\$2,\$3, 10^(\$12 * -1.0) );}' "
                publishDir = [
                        path: {"${params.outdir}/RVTESTS"},
                        saveAs: { filename -> "${params.prefix}$filename" },
                        mode: "copy",
                        pattern : '*.{png}',
                        overwrite : true
                        ]
                }
        withName: "BEST_HITS" {
                publishDir = [
                        path: {"${params.outdir}/RVTESTS"},
                        saveAs: { filename -> "${params.prefix}$filename" },
                        mode: "copy",
                        pattern : '*.{tsv}',
                        overwrite : true
                        ]
                }

        withName: "CIRCULAR_MANHATTAN:FAI_TO_SVG:FAI2BED" {
                ext.awk_expr  = "(\$1 ~ /^(chr)?[0-9X]+\$/)" /* no need Y; regenie ignores it */
                }
      

        withName: "CIRCULAR_MANHATTAN:FAI_TO_SVG:BED_TO_XML" {
                ext.args1  = "--regex '^(chr)?[0-9X]+\$' " /* no need Y; regenie ignores it */
                ext.with_dict  = true
                }
   
        withName : "CIRCULAR_MANHATTAN:CYTOBAND_TO_SVG:BED_TO_XML" {
                ext.args1 = {" --columns name,color"}
                }
        withName : "CIRCULAR_MANHATTAN:CYTOBAND_TO_SVG:XSLTPROC" {
                ext.args1 = {"--stringparam radius_R1 1000 -stringparam radius_R2 950  "}
                }


        withName: "CIRCULAR_MANHATTAN:BED_TO_XML" {
                // add a random value to BED
                ext.cmd1 = "awk -F ' ' '/^CHROM/ {next} (\$12!=\"NA\") {P_VALUE = \$12*1.0; STYLE=\"\"; TITLE = \"\"; if(P_VALUE > 4) { TITLE = sprintf(\"%s:%s %s p=%s\",\$1,\$2,\$3,\$12); } if(P_VALUE > 7) {STYLE=\"fill:red;opacity:1.0;\" } else if(P_VALUE > 4 ) {STYLE=\"fill:orange;opacity:1.0;\"}; printf(\"%s\t%d\t%s\t%s\t%s\t%s\\n\", \$1, int(\$2)-1, \$2 ,\$12, TITLE, STYLE);}' "  
                ext.args1 = "--columns value,title,style"
                }


        withName: "CIRCULAR_MANHATTAN:XSLTPROC" {
		ext.args1 = {"--stringparam class donut_1  --stringparam title \"${meta.id}\" --stringparam radius_R1 900 -stringparam radius_R2 100  "}
        	}
        withName : "BATIK:BATIK_RASTERIZE_PDF|BATIK:BATIK_RASTERIZE_PNG" {
	        memory = {10.GB * task.attempt}
                publishDir = [
                        path:"${params.outdir}/RVTESTS",
                        saveAs: { filename -> "${params.prefix}$filename" },
                        mode: "copy",
                        pattern : '*.{pdf,png}',
                        overwrite : true
                        ]
                }


	withName : "ZIP" {
                publishDir = [
                path: {"${params.outdir}/RVTESTS"},
                saveAs: { filename -> "${params.prefix}$filename" },
                mode: "copy",
                pattern : '*.zip',
                overwrite : true
                ]
	}

        withName: "MULTIQC" {
                publishDir = [
                        path: { "${params.outdir}/multiqc" },
                         saveAs: { filename -> "${params.prefix}$filename" },
                        mode: "copy",
                        pattern : '*.{zip}',
                        overwrite : true
                        ]
                }


        /*
	withName : "ANNOT_HITS" {
                publishDir = [
                path: {"${params.outdir}/REGENIE"},
                saveAs: { filename -> "${params.prefix}$filename" },
                mode: "copy",
                pattern : '*.{tsv}',
                overwrite : true
                ]
        }*/

        /*
	withName : "MAKE_SNPLIST" {
                publishDir = [
                path: {"${params.outdir}/REGENIE"},
                saveAs: { filename -> "${params.prefix}$filename" },
                mode: "copy",
                pattern : '*.{gz}',
                overwrite : true
                ]
        }*/

        /*
	withName : "README" {
                publishDir = [
                path: {"${params.outdir}"},
                mode: "copy",
                pattern : '*.{md}',
                overwrite : true
                ]
        }*/


}

