
plugins {
  id 'nf-schema@2.6.1'
}

includeConfig "../../config/common.schema.config"




params {
	/* file containing the path to multiple bam files */
	bams = "NO_FILE"
	/* path to indexed vcf file to genotype */
	vcf = "NO_FILE"
	/** method used for genotyping '(gatk|bcftools|graphtyper)'*/
	method = "gatk"//
        dbsnp = null
        outdir="results"
        fasta = null
        n_bams = 50
        n_variants = 10000
        with_stats = true
        with_multiqc = true
        recal_snps_args = null
        recal_indels_args = null
        minigenotyper_mode="random_access"
        
	}
includeConfig "../../config/nextflow.config"

/** END_PARAMS */

process {


withName : "PREPARE_ONE_REFERENCE:PREPARE_REFERENCE:SCATTER_TO_BED:SCATTER_INTERVALS_BY_NS" {
        ext.output_type = "ACGT"
        ext.max_to_merge = 1
	}

withName:  "SPLIT_N_VARIANTS" {
	array = 100
        ext.method = {"--variants-count ${params.n_variants} "}
        }
withName:  "BCFTOOLS_MERGE" {
        cpus = {task.attempt==1?20:10}
        ext.tags = ""
        ext.args1 = {params.method=="jvarkit"?"--no-index  ":""}
        }

withName:  "BCFTOOLS_CONCAT" {
        cpus = 20
        publishDir = [
                path:"${params.outdir}/VCF",
                saveAs: { filename -> "${params.prefix}${filename}" },
                mode: "copy",
                pattern : '*.{bcf,vcf.gz,tbi,csi,md5}',
                overwrite : true
                ]
        }
withName : "VCF2TABIX" {
        time = 10.m
        }
withName: "BCFTOOLS_GENOTYPE" {
        memory = 10.GB
        cpus = 5
        ext.annotations1 = "-a 'FORMAT/AD' -a 'FORMAT/DP'"
        ext.annotations2 = ""
        }
withName: "BIM_TO_VCF" {
        /* remove indels */
        ext.awk_expr="(\$5 ~ /^[ATGC]\$/ && \$6 ~ /^[ATGC]\$/)"
        }

withName : "GATK_GENOTYPE_VCF" {
	ext.args1 = "--max-alternate-alleles 1 --do-not-run-physical-phasing --disable-tool-default-annotations --dont-use-soft-clipped-bases -A DepthPerSampleHC -A DepthPerAlleleBySample"
	}

withName: "MINIGENOTYPER" {
        ext.args1 = {"--mode ${params.minigenotyper_mode}"}
        }


withName: "GRAPHTYPER" {
        memory = 50.GB
        cpus = 10
        }
withName: "BCFTOOLS_QUERY" {
	array = 100
        ext.format = "%CHROM\t%POS0\t%END\\n"
        ext.suffix = "vcf2bed.bed"
        }
withName: "BEDTOOLS_SLOP" {
	array = 100
        ext.slop="25000"
        }
withName: "BEDTOOLS_MERGE" {
	array = 100
        }
}
