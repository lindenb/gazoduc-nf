plugins {
  id 'nf-schema@2.6.1'
}

includeConfig "../../config/common.schema.config"


params {
	samplesheet = null
	bed = null
	min_sv_len = 200
	max_sv_len = 1000000
        gtf=null
	}

includeConfig "../../config/nextflow.config"

process {

        withName : "EXTEND_BED" {
                ext.max_sv_length  = {params.max_sv_len}
                ext.min_sv_length  = {params.min_sv_len}
        }


     

        withName : "ZIP_ALL|MERGE_PDFS" {
                publishDir = [
                        path:"${params.outdir}/PDFS",
                        saveAs: { filename -> "${params.prefix}$filename" },
                        mode: "copy",
                        pattern : '*.{zip,pdf}',
                        overwrite : true
                        ]

                }

}
