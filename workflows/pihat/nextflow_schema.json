{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PIHAT pipeline parameters",
  "$id": "https://raw.githubusercontent.com/gazoduc/master/nextflow_schema.json",
  "description": "PIHAT Pipeline",
  "type": "object",
  "$defs": {
    "input_and_output_params": {
      "title": "Input / Ouput",
      "type": "object",
      "description": "General Parameters",
      "required": ["fasta","samplesheet","gnomad"],
      "properties": {
        "fasta": {
          "type": "string",
          "format": "file-path",
          "exists": true,
          "mimetype": "text/plain",
          "pattern": "^\\S+\\.(fasta|fa|fna)?(\\.gz)?$",
          "description": "Path to FASTA REFERENCE file.",
          "fa_icon": "far fa-file-code"
        },
        "samplesheet": {
          "type": "string",
          "format": "file-path",
          "exists": true,
          "mimetype": "text/plain",
          "description": "Path to Samplesheet.",
          "fa_icon": "far fa-file-code"
        },
        "gnomad": {
          "type": "string",
          "format": "file-path",
          "exists": true,
          "mimetype": "text/plain",
          "description": "Path to gnomad.",
          "fa_icon": "far fa-file-code"
        },
        "prefix": {
          "type": "string",
          "pattern": "^[a-zA-z0-9_\\.]+\\.$",
          "description": "prefix for the save files. A good prefix would be 'YYYY-MM-DD.project_name.' ",
          "help_text": "Ouput file prefix"
        },
        "extra_cluster_options": {
          "type": "string",
          "description": "extra parameters for the cluster. Can be used to exclude a node for example"
        },
        "help": {
          "type": "boolean"
        }
      }
    }
    
},
  "allOf": [
    { "$ref": "#/$defs/input_and_output_params" }
  ]
}
