plugins {
  id 'nf-schema@2.6.1'
}

includeConfig "../../../config/common.schema.config"

params {
    help = false
    outdir = "results"
    fasta =null
    vcf = null
    prefix = ""
    with_alphamissense = true
    vcffilterso_args = "--filterout BAD_SO"
    vcfgnomad_bcftools_args="" // -e "FILTER ~ 'GNOMAD_GENOME_AC0'   || FILTER ~ 'GNOMAD_GENOME_AS_VQSR'   || FILTER ~ 'GNOMAD_GENOME_BAD_AF'   || FILTER ~ 'GNOMAD_GENOME_InbreedingCoeff'"
    cases = null
    controls =  null
}

includeConfig "../../../config/nextflow.config"


params {
        gnomadAF = 0.01
        gnomadPop= "AF_nfe"
        soacn = "SO:0001574,SO:0001575,SO:0001818"
        split_n_variants_args="--distance 1Mb"
        }

conda.enabled=true


process {

withName: "SPLIT_N_VARIANTS" {
        ext.method= {"${params.split_n_variants_args}"}
        }


withName: "JVARKIT_VCFGNOMAD" {
        ext.max_af = {"${params.gnomadAF}"}
        ext.fields = {"${params.gnomadPop}"}
	ext.args2 = {" ${params.vcfgnomad_bcftools_args} "}
        }

withName: "SNPEFF_APPLY" {
        ext.accessions = {"${params.soacn}"}
        ext.args3 = {" ${params.vcffilterso_args} "}
        }


withName: "JVARKIT_VCF_FLATTEN" {
        ext.args2= "-X '+1kb,+10kb,+100kb,ANN/GeneId,ANN/FeatureId' "
	}

withName : "BCFTOOLS_CONCAT" {
        cpus = 10

        publishDir = [
                path:"${params.outdir}",
                saveAs: { filename -> "${params.prefix}$filename" },
                mode: "copy",
                pattern : '*.{bcf,csi,vcf.gz,tbi,md5}',
                overwrite : true
                ]
        }

withName : "GROUP_BY_GENE|CONTRAST2" {
        publishDir = [
                path:"${params.outdir}",
                saveAs: { filename -> "${params.prefix}$filename" },
                mode: "copy",
                //pattern : '*.{bed,}',
                overwrite : true
                ]
	}

}

