nextflow_process {

    name "Test Process PLINK2_VCF2PGEN"
    script "modules/plink/vcf2pgen/main.nf"
    process "PLINK2_VCF2PGEN"
    tag "gitlab_ci"
    tag "modules"
    tag "modules/plink"
    tag "modules/plink/vcf2pgen"

    test("BASIC") {
        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [[id:"ref",ucsc_name:"hg19"], [] ]
                input[1] = [[id:"ped"], []]
                input[2] = [[id:"ALL.chr22.shapeit2_integrated_snvindels_v2a_27022019.GRCh38.phased"], file("${projectDir}/tests/data/ALL.chr22.shapeit2_integrated_snvindels_v2a_27022019.GRCh38.phased.vcf.gz")]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }
    }


    test("STUB") {
        options "-stub"
        tag "stub"
        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [[id:"ref",ucsc_name:"hg19"], file("${projectDir}/tests/data/rotavirus_rf.fa")]
                input[1] = [[id:"ped"], file("${projectDir}/tests/data/plink.ped")]
                input[2] = [[id:"rota"], file("${projectDir}/tests/data/rotavirus_rf.vcf.gz")]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }
    }

}
