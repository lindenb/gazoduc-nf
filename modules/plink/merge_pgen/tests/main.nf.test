nextflow_process {

    name "Test Process PLINK2_MERGE_PGEN"
    script "modules/plink/merge_pgen/main.nf"
    process "PLINK2_MERGE_PGEN"
    tag "modules"
    tag "modules/plink"
    tag "modules/plink/merge_pgen"
    tag "gitlab_ci"

    test("SINGLE") {

        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [[id:"zorg"],
                        [
                        file("${projectDir}/tests/data/ALL.chr22.shapeit2_integrated_snvindels_v2a_27022019.GRCh38.phased.pgen"),
                        file("${projectDir}/tests/data/ALL.chr22.shapeit2_integrated_snvindels_v2a_27022019.GRCh38.phased.psam"),
                        file("${projectDir}/tests/data/ALL.chr22.shapeit2_integrated_snvindels_v2a_27022019.GRCh38.phased.pvar")
                        ]
                    ]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }

    }

    test("STUB") {
        options "-stub"
        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [[id:"zorg"],
                        [
                        file("${projectDir}/tests/data/ALL.chr22.shapeit2_integrated_snvindels_v2a_27022019.GRCh38.phased.pgen"),
                        file("${projectDir}/tests/data/ALL.chr22.shapeit2_integrated_snvindels_v2a_27022019.GRCh38.phased.psam"),
                        file("${projectDir}/tests/data/ALL.chr22.shapeit2_integrated_snvindels_v2a_27022019.GRCh38.phased.pvar")
                        ]
                    ]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }

    }
}
