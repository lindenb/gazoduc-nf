nextflow_process {

    name "Test Process GATK_GENOTYPE_VCF"
    script "modules/gatk/genotypevcf/main.nf"
    process "GATK_GENOTYPE_VCF"
    tag "gitlab_ci"
    tag "modules"
    tag "modules/gatk"
    tag "modules/gatk/genotypevcf"

    test("BASIC") {

        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
				input[0] = [ [id:"ref"],file("${projectDir}/tests/data/rotavirus_rf.fa")]
				input[1] = [ [id:"ref"],file("${projectDir}/tests/data/rotavirus_rf.fa.fai")]
				input[2] = [ [id:"ref"],file("${projectDir}/tests/data/rotavirus_rf.dict")]
  				input[3] = [ [id:"nodbsnp"],[], []]
                input[4] = [ [id:"x1"],file("${projectDir}/tests/data/rotavirus_rf.vcf.gz"),file("${projectDir}/tests/data/rotavirus_rf.vcf.gz.tbi")]
                input[5] = [ [id:"bams"],[
                    file("${projectDir}/tests/data/S1.bam"),
                    file("${projectDir}/tests/data/S1.bam.bai"),
                    file("${projectDir}/tests/data/S2.bam"),
                    file("${projectDir}/tests/data/S2.bam.bai"),
                    file("${projectDir}/tests/data/S3.bam"),
                    file("${projectDir}/tests/data/S3.bam.bai")
                    ]  ]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }
    }
    
    test("STUB") {
        options "-stub"
        tag "stub"
        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
				input[0] = [ [id:"ref"],file("${projectDir}/tests/data/rotavirus_rf.fa")]
				input[1] = [ [id:"ref"],file("${projectDir}/tests/data/rotavirus_rf.fa.fai")]
				input[2] = [ [id:"ref"],file("${projectDir}/tests/data/rotavirus_rf.dict")]
  				input[3] = [ [id:"nodbsnp"],[], []]
                input[4] = [ [id:"x1"],file("${projectDir}/tests/data/rotavirus_rf.vcf.gz"),file("${projectDir}/tests/data/rotavirus_rf.vcf.gz.tbi")]
                input[5] = [ [id:"bams"],[
                    file("${projectDir}/tests/data/S1.bam"),
                    file("${projectDir}/tests/data/S1.bam.bai"),
                    file("${projectDir}/tests/data/S2.bam"),
                    file("${projectDir}/tests/data/S2.bam.bai"),
                    file("${projectDir}/tests/data/S3.bam"),
                    file("${projectDir}/tests/data/S3.bam.bai")
                    ]  ]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }

    }
}
