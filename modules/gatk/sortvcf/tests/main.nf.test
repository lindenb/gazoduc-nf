nextflow_process {

    name "Test Process SORT_VCF"
    script "modules/gatk/sortvcf/main.nf"
    process "SORT_VCF"
    tag "gitlab_ci"
    tag "modules"
    tag "modules/gatk"
    tag "modules/gatk/sortvcf"

    test("BASIC") {

        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [[id:"output"],file("${projectDir}/tests/data/rotavirus_rf.vcf.gz")]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }

    }


    test("STUB") {
        options "-stub"
        tag "stub"
        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [[id:"output"],file("${projectDir}/tests/data/rotavirus_rf.vcf.gz")]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }

    }

}
