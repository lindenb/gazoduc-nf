nextflow_process {

    name "Test Process JVARKIT_MULTIQCPOSTPROC"
    script "modules/jvarkit/multiqcpostproc/main.nf"
    process "JVARKIT_MULTIQCPOSTPROC"
    // tag "gitlab_ci" TODO update when conda OK
    tag "modules"
    tag "modules/jvarkit"
    tag "modules/jvarkit/multiqcpostproc"


    test("STUB") {
        tag "gitlab_ci"
        tag "stub"
        options "-stub"
        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
	            input[0] = [[id:"x1"],file("sample2pop.tsv")]
                input[1] = [[id:"x2"],file("custom.txt")]
                input[2] = [[id:"x3"],file("DIR")]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }

    }

}
