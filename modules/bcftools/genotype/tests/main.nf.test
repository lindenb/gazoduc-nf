nextflow_process {
    name "Test Process BCFTOOLS_GENOTYPE"
    script "modules/bcftools/genotype/main.nf"
    process "BCFTOOLS_GENOTYPE"
    tag "gitlab_ci"
    tag "modules"
    tag "modules/bcftools"
    tag "modules/bcftools/genotype"

    test("BASIC") {


        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [ [id:"zorg"], file("${projectDir}/tests/data/rotavirus_rf.fa") ]
                input[1] = [ [id:"zorg"], file("${projectDir}/tests/data/rotavirus_rf.fa.fai") ]
                input[2] = [ [id:"zorg"], file("${projectDir}/tests/data/rotavirus_rf.to_genotype.tsv.gz"), file("${projectDir}/tests/data/rotavirus_rf.to_genotype.tsv.gz.tbi") ]
                input[3] = [ [id:"S1"  ],[
                     file("${projectDir}/tests/data/S1.bam"), file("${projectDir}/tests/data/S1.bam.bai"),
                     file("${projectDir}/tests/data/S2.bam"), file("${projectDir}/tests/data/S2.bam.bai"),
                     file("${projectDir}/tests/data/S3.bam"), file("${projectDir}/tests/data/S3.bam.bai")
                     ]]     
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }

    }



    test("STUB") {
	tag "stub"
	options "-stub"

        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [ [id:"zorg"], file("${projectDir}/tests/data/rotavirus_rf.fa") ]
                input[1] = [ [id:"zorg"], file("${projectDir}/tests/data/rotavirus_rf.fa.fai") ]
                input[2] = [ [id:"zorg"], file("${projectDir}/tests/data/tests/data/rotavirus_rf.to_genotype.tsv.gz"), file("${projectDir}/tests/data/tests/data/rotavirus_rf.to_genotype.tsv.gz.tbi") ]
                input[3] = [ [id:"S1"  ],[
                     file("${projectDir}/tests/data/S1.bam"), file("${projectDir}/tests/data/S1.bam.bai"),
                     file("${projectDir}/tests/data/S2.bam"), file("${projectDir}/tests/data/S2.bam.bai"),
                     file("${projectDir}/tests/data/S3.bam"), file("${projectDir}/tests/data/S3.bam.bai")
                     ]]     
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }

    }


}
