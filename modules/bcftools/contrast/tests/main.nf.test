nextflow_process {

    name "Test Process BCFTOOLS_CONTRAST"
    script "modules/bcftools/contrast/main.nf"
    process "BCFTOOLS_CONTRAST"
    tag "gitlab_ci"
    tag "modules"
    tag "modules/bcftools"
    tag "modules/bcftools/contrast"
   


    test("STUB") {
        options "-stub"
        tag "stub"
        when {
            
            process {
                """
               input[0] = [[id:"m1"],file("cases")]
               input[1] = [[id:"m2"],file("controls")]
               input[2] = [[id:"m3"],file("input.vcf.gz")]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }

    }


}
