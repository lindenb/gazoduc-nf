nextflow_process {

    name "Test Process BCFTOOLS_MERGE"
    script "modules/bcftools/merge3/main.nf"
    process "BCFTOOLS_MERGE"
    tag "gitlab_ci"
    tag "modules"
    tag "modules/bcftools"
    tag "modules/bcftools/merge3"



    test("ONE") {

        when {

            process {
                """
               input[0] = [[id:"one"],[
                        file("${projectDir}/tests/data/S1.vcf.gz"),
                        file("${projectDir}/tests/data/S1.vcf.gz.tbi")
                        ]]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }

    }

      test("MULTI") {

        when {

            process {
                """
               input[0] = [[id:"multi"],[
                        file("${projectDir}/tests/data/S1.vcf.gz"),
                        file("${projectDir}/tests/data/S1.vcf.gz.tbi"),
                        file("${projectDir}/tests/data/S2.vcf.gz"),
                        file("${projectDir}/tests/data/S2.vcf.gz.tbi"),
                        file("${projectDir}/tests/data/S3.vcf.gz"),
                        file("${projectDir}/tests/data/S3.vcf.gz.tbi"),
                        file("${projectDir}/tests/data/S4.vcf.gz"),
                        file("${projectDir}/tests/data/S4.vcf.gz.tbi")
                        ]]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }

    }

    test("STUB") {
        options "-stub"
        tag "stub"
        
        when {

            process {
                """
               input[0] = [[id:"stub"],
                        [
                        file("${projectDir}/tests/data/rotavirus_rf.vcf.gz"),
                        file("${projectDir}/tests/data/rotavirus_rf.vcf.gz.tbi")
                        ]]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }

    }


}
