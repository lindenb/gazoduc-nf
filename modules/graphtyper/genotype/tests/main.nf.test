nextflow_process {

    name "Test Process GRAPHTYPER"
    script "modules/graphtyper/genotype/main.nf"
    process "GRAPHTYPER"
    tag "modules"
    tag "modules/graphtyper"
    tag "modules/graphtyper/genotype"
    tag "gitlab_ci"


    test("WITH_VCF") {
        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [[id:"ref"],file("${projectDir}/tests/data/rotavirus_rf.fa")]
                input[1] = [[id:"ref"],file("${projectDir}/tests/data/rotavirus_rf.fa.fai")]
                input[2] = [[id:"depth"],[]]
                input[3] = [[id:"vcf"],file("${projectDir}/tests/data/rotavirus_rf.vcf.gz"),file("${projectDir}/tests/data/rotavirus_rf.vcf.gz.tbi")]
                input[4] = [[id:"bed"],[]]
                input[5] = [[id:"z"],[
                    file("${projectDir}/tests/data/S1.bam"),
                    file("${projectDir}/tests/data/S1.bam.bai"),
                    file("${projectDir}/tests/data/S2.bam"),
                    file("${projectDir}/tests/data/S2.bam.bai")
                    ]]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }

    }



    test("WITH_BED") {
        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [[id:"ref"],file("${projectDir}/tests/data/rotavirus_rf.fa")]
                input[1] = [[id:"ref"],file("${projectDir}/tests/data/rotavirus_rf.fa.fai")]
                input[2] = [[id:"depth"],[]]
                input[3] = [[id:"vcf"],[],[]]
                input[4] = [[id:"bed"],file("${projectDir}/tests/data/rotavirus_rf.01.bed")]
                input[5] = [[id:"z"],[
                    file("${projectDir}/tests/data/S1.bam"),
                    file("${projectDir}/tests/data/S1.bam.bai"),
                    file("${projectDir}/tests/data/S2.bam"),
                    file("${projectDir}/tests/data/S2.bam.bai")
                    ]]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }

    }

    test("STUB") {
        options "-stub"
        tag "stub"
        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [[id:"ref"],file("${projectDir}/tests/data/rotavirus_rf.fa")]
                input[1] = [[id:"ref"],file("${projectDir}/tests/data/rotavirus_rf.fa.fai")]
                input[2] = [[id:"ref"],[]]
                input[3] = [[id:"vcf"],file("${projectDir}/tests/data/rotavirus_rf.vcf.gz"),file("${projectDir}/tests/data/rotavirus_rf.vcf.gz.tbi")]
                input[4] = [[id:"bed"],[]]
                input[5] = [[id:"z"],[
                    file("${projectDir}/tests/data/S1.bam"),
                    file("${projectDir}/tests/data/S1.bam.bai"),
                    file("${projectDir}/tests/data/S2.bam"),
                    file("${projectDir}/tests/data/S2.bam.bai")
                    ]]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }

    }
}
