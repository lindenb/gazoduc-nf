nextflow_process {

    name "Test Process ZIP"
    script "modules/utils/zip/main.nf"
    process "ZIP"
    tag "gitlab_ci"
    tag "modules"
    tag "modules/utils"
    tag "modules/utils/zip"
    
    test("BASIC") {
        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [[id:"test01"], [file("${projectDir}/tests/data/rotavirus_rf.01.bed"),file("${projectDir}/tests/data/rotavirus_rf.02.bed")]]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }
    }

   

    test("STUB") {
        tag "stub"
        options "-stub"
        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [[id:"test01"], [file("${projectDir}/tests/data/rotavirus_rf.01.bed"),file("${projectDir}/tests/data/rotavirus_rf.02.bed")]]
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }
    }
}
